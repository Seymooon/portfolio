---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Video Editing" activePage="skills">
  <main class="py-16">
    <div class="wrap">
      <a href="/skills" class="text-sm font-mono text-paper-dim hover:text-coral transition-colors">&larr; Back to Tracks</a>
      <h1 class="text-4xl font-display font-bold mt-4 mb-2">Video Editing</h1>
      <p class="text-paper-dim max-w-2xl mb-12">Fine-tuning sequences framework down to the exact frame.</p>

      <h3 class="text-xl font-mono text-gold mb-6">Project Gallery</h3>
      <div class="gallery-grid">
        <div class="gallery-item"><span>00:01:14:12</span></div>
        <div class="gallery-item"><span>00:03:45:00</span></div>
        <div class="gallery-item"><span>00:05:22:18</span></div>
      </div>
    </div>
  </main>
</Layout>