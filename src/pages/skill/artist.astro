---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Digital Art" activePage="skills">
  <main class="py-16">
    <div class="wrap">
      <a href="/skills" class="text-sm font-mono text-paper-dim hover:text-gold transition-colors">&larr; Back to Tracks</a>
      <h1 class="text-4xl font-display font-bold mt-4 mb-2">Digital Art</h1>
      <p class="text-paper-dim max-w-2xl mb-12">Structuring environment spaces and vector asset renders.</p>

      <h3 class="text-xl font-mono text-gold mb-6">Canvas Renders</h3>
      <div class="gallery-grid">
        <div class="gallery-item"><span>layer_01.png</span></div>
        <div class="gallery-item"><span>layer_02.png</span></div>
        <div class="gallery-item"><span>final_flat.tiff</span></div>
      </div>
    </div>
  </main>
</Layout>