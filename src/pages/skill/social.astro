---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Social Media Management" activePage="skills">
  <main class="py-16">
    <div class="wrap max-w-5xl mx-auto px-6">
      <a href="/skills" class="text-sm font-mono text-paper-dim hover:text-[#A3C1AD] transition-colors">&larr; Back to Tracks</a>
      <h1 class="text-4xl font-display font-bold mt-4 mb-8 text-white">Communication Archive</h1>

      <div class="flex flex-col md:flex-row gap-8 min-h-[500px]">
        <div class="w-full md:w-1/3 space-y-2">
          <h3 class="text-xs font-mono text-[#A3C1AD] uppercase tracking-wider mb-4">// Inbox</h3>
          <button class="email-trigger w-full text-left p-4 rounded-lg bg-gray-900 border border-gray-700 hover:border-[#A3C1AD] transition-all" data-id="email1">
            <div class="font-bold text-white">Interview Confirmation</div>
            <div class="text-xs text-gray-500">Recruitment coordination</div>
          </button>
          <button class="email-trigger w-full text-left p-4 rounded-lg bg-gray-900 border border-gray-700 hover:border-[#A3C1AD] transition-all" data-id="email2">
            <div class="font-bold text-white">Client Proposal</div>
            <div class="text-xs text-gray-500">Awaiting response</div>
          </button>
          <button class="email-trigger w-full text-left p-4 rounded-lg bg-gray-900 border border-gray-700 hover:border-[#A3C1AD] transition-all" data-id="email3">
            <div class="font-bold text-white">Operations Summary</div>
            <div class="text-xs text-gray-500">Workflow completed</div>
          </button>
        </div>

        <div class="flex-1 bg-white p-8 rounded-lg shadow-xl text-slate-900" id="email-display">
          <div class="text-center py-20 text-gray-400 italic">Select an email to view details</div>
        </div>
      </div>
    </div>
  </main>

  <div id="templates" class="hidden">
    <div id="email1">
      <h2 class="text-2xl font-bold mb-4">Interview Schedule Confirmation</h2>
      <div class="flex gap-2 mb-6">
        <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-bold rounded">Recruitment</span>
        <span class="px-2 py-1 bg-green-100 text-green-800 text-xs font-bold rounded">Confirmed</span>
      </div>
      <p class="mb-4">Greetings!</p>
      <p class="mb-4">Your interview is scheduled for Friday, July 10, 2026, at 2:00 PM EST. A Google Calendar invitation has been sent...</p>
      <p class="font-semibold mt-8">— John Simon Gutang</p>
    </div>

    <div id="email2">
      <h2 class="text-2xl font-bold mb-4">Client Proposal Follow-up</h2>
      <div class="flex gap-2 mb-6">
        <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded">Pending</span>
      </div>
      <p class="mb-4">Hello,</p>
      <p class="mb-4">Following up on the proposal sent earlier this week regarding the social media strategy overhaul. Let me know if you have any questions.</p>
      <p class="font-semibold mt-8">— John Simon Gutang</p>
    </div>

    <div id="email3">
      <h2 class="text-2xl font-bold mb-4">Operations Summary</h2>
      <div class="flex gap-2 mb-6">
        <span class="px-2 py-1 bg-gray-200 text-gray-800 text-xs font-bold rounded">Internal</span>
      </div>
      <p class="mb-4">Hi Team,</p>
      <p class="mb-4">The weekly workflow automation tasks have been completed. All data entries are synced and ready for review.</p>
      <p class="font-semibold mt-8">— John Simon Gutang</p>
    </div>
  </div>

  <script>
    const triggers = document.querySelectorAll('.email-trigger');
    const display = document.getElementById('email-display');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const id = trigger.getAttribute('data-id');
        const content = document.getElementById(id).innerHTML;
        display.innerHTML = content;
        
        // Highlight active button
        triggers.forEach(t => t.classList.remove('border-[#A3C1AD]'));
        trigger.classList.add('border-[#A3C1AD]');
      });
    });
  </script>
</Layout>