---
import Layout from "../../layouts/Layout.astro";

const gallery = [
  { type: "image", src: "/media/1.jpg" },
  { type: "image", src: "/media/2.jpg" },
  { type: "image", src: "/media/3.jpg" },
  { type: "image", src: "/media/4.jpg" },
  { type: "image", src: "/media/5.jpg" },
  { type: "image", src: "/media/6.jpg" },

  {
    type: "video",
    src: "/media/vid1.mp4",
    thumbnail: "/media/thumb1.jpg",
  },
  {
    type: "video",
    src: "/media/vid2.mp4",
    thumbnail: "/media/thumb2.jpg",
  },
  {
    type: "video",
    src: "/media/vid3.mp4",
    thumbnail: "/media/thumb3.jpg",
  },
];
---

<Layout title="Gallery" activePage="skills">
<main
  class="min-h-screen transition-colors duration-300"
  style="background: var(--ink); color: var(--paper);"
>

<section class="mx-auto max-w-7xl px-8 pt-16 pb-24">

<a
  href="/skills"
  class="text-sm font-mono mb-4 inline-block transition-colors duration-200"
  style="color: var(--paper-dim);"
  onmouseover="this.style.color='var(--accent)'"
  onmouseout="this.style.color='var(--paper-dim)'"
>
  ← GO BACK
</a>

<h1
  class="mb-4 text-center text-6xl font-display font-bold transition-colors"
  style="color: var(--paper);"
>
Gallery
</h1>

<p
  class="mx-auto mb-16 max-w-3xl text-center text-lg leading-relaxed"
  style="color: var(--paper-dim);"
>
A few samples of media work.
</p>

<div
id="carousel"
class="relative h-[640px] overflow-visible"
>

{
gallery.map((item,index)=>(

<div
  class="carousel-card absolute left-1/2 top-1/2
         w-[320px]
         h-[460px]
         rounded-3xl
         overflow-hidden
         shadow-2xl
         cursor-pointer
         select-none"
  style="
    background: var(--surface);
    border: 1px solid var(--line);
  "
 data-index={index}
data-type={item.type}
data-src={item.src}
>
{
item.type === "image" ? (

 <img
  src={item.src}
  alt=""
  draggable="false"
  class="h-full w-full object-cover pointer-events-none select-none"
/>

) : (

  <div class="relative h-full w-full">

    <img
  src={item.thumbnail ?? item.src}
  alt=""
  draggable="false"
  class="h-full w-full object-cover pointer-events-none select-none"
/>

    <div class="absolute inset-0 flex items-center justify-center">

      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-black/60 backdrop-blur">

        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="white"
          class="h-8 w-8 ml-1"
        >
          <path d="M8 5v14l11-7z"/>
        </svg>

      </div>

    </div>

  </div>

)
}


</div>

))
}

</div>

</section>

</main>

<style>

#lightbox{

opacity:0;

transition:opacity .3s;

}

#lightbox.flex{

opacity:1;

display:flex;

}

#lightbox img,
#lightbox video{

animation:popup .25s ease;

}

@keyframes popup{

from{

opacity:0;
transform:scale(.9);

}

to{

opacity:1;
transform:scale(1);

}

}

.carousel-card {
  touch-action: none;
user-select: none;
-webkit-user-select: none;

left:50%;
top:40%;

transform:translate(-50%,-50%);

will-change:transform,opacity;

backface-visibility:hidden;

transform-style:preserve-3d;

transition:
box-shadow .25s ease,
filter .25s ease;

box-shadow:
0 20px 60px rgba(0,0,0,.15);

}

:root[data-theme="dark"] .carousel-card{

box-shadow:
0 20px 60px rgba(0,0,0,.45);

}

</style>

<div
  id="lightbox"
  class="fixed inset-0 hidden items-center justify-center bg-black/90 dark:bg-black/90 backdrop-blur-md"
  style="z-index:99999;"
>

  <button
    id="close-lightbox"
    class="absolute right-8 top-8 z-50 text-5xl text-white transition hover:text-emerald-400"
  >
    ×
  </button>

  <div
    id="lightbox-content"
    class="relative flex max-h-[90vh] max-w-[90vw] items-center justify-center"
  >
  </div>

</div>

<script is:inline>

document.addEventListener("astro:page-load", () => {

const carousel = document.getElementById("carousel");
const cards = [...document.querySelectorAll(".carousel-card")];
carousel.addEventListener("dragstart", (e) => {
  e.preventDefault();
});



let position = 0;
let target = 0;

let dragging = false;
let startX = 0;
let hasDragged = false;

const total = cards.length;

let paused = false;
let speed = 0.006;
let hoveredCard = null;

// ----------------------
// Pause on hover
// ----------------------

cards.forEach((card) => {

    card.addEventListener("mouseenter", () => {

        if (dragging) return;

        hoveredCard = card;

    });

    card.addEventListener("mouseleave", () => {

        paused = false;
        hoveredCard = null;

        speed = 0.03;

    });

});

// ----------------------
// Mouse Drag
// ----------------------

carousel.addEventListener("pointerdown", (e) => {

  // carousel.setPointerCapture(e.pointerId);

  dragging = true;
  hasDragged = false;
  startX = e.clientX;

});

carousel.addEventListener("pointerup", () => {
  dragging = false;
});

carousel.addEventListener("pointermove", (e) => {

  if (!dragging) return;

  const dx = e.clientX - startX;

if (Math.abs(dx) > 3) {
    hasDragged = true;
}

target -= dx * 0.012;

paused = false;
hoveredCard = null;

startX = e.clientX;

});

// ----------------------
// Touch Drag
// ----------------------

carousel.addEventListener("touchstart", (e)=>{

  dragging = true;
  startX = e.touches[0].clientX;

},{passive:true});

window.addEventListener("touchmove",(e)=>{

  if(!dragging) return;

  const dx = e.touches[0].clientX - startX;

if (Math.abs(dx) > 3) {
    hasDragged = true;
}

target -= dx * 0.012;

  startX = e.touches[0].clientX;

},{passive:true});

window.addEventListener("touchend",()=>{

  dragging=false;

});

// ----------------------
// Animation
// ----------------------

function animate(){

    if (!paused && !dragging) {

    target += speed;

    // Smoothly return to the normal speed
    speed += (0.006 - speed) * 0.08;

}

    position += (target-position)*0.08;

    cards.forEach((card,index)=>{

        let offset = index-position;

        while(offset < -total/2) offset += total;
        while(offset > total/2) offset -= total;

        const d = Math.abs(offset);

        const x = Math.sin(offset * 0.65) * 470;

        const y = Math.pow(d,1.3) * 10;

        let scale =
0.72 +
Math.pow(Math.max(0, Math.cos(offset * 0.45)), 1.4) * 0.28;

if (card === hoveredCard) {

    scale *= 1.2;

}

        const rotate = offset * -18;

        const opacity = Math.max(
  0.35,
  1 - d * 0.18
);

const brightness = Math.max(
  0.65,
  1 - d * 0.10
);

const z = Math.max(
  1,
  Math.floor((10 - d) * 10)
);

        card.style.transform = `
        translate(-50%,-50%)
        translateX(${x}px)
        translateY(${y}px)
        scale(${scale})
        rotateY(${rotate}deg)
        `;

        card.style.opacity = opacity;

        card.style.zIndex = z;

        card.style.filter = `
        brightness(${brightness})
        `;

    });

    requestAnimationFrame(animate);

}

requestAnimationFrame(() => {
    requestAnimationFrame(() => {
        animate();
    });
});

// --------------------
// Lightbox
// --------------------

const lightbox = document.getElementById("lightbox");
const content = document.getElementById("lightbox-content");
const closeBtn = document.getElementById("close-lightbox");

function closeLightbox(){

    const video = content.querySelector("video");

    if(video){

        video.pause();

    }

    content.innerHTML="";

    lightbox.classList.remove("flex");
    lightbox.classList.add("hidden");

}

cards.forEach((card) => {

  card.addEventListener("click", () => {

    if (hasDragged) {
      hasDragged = false;
      return;
    }

    const type = card.dataset.type;
    const src = card.dataset.src;

    content.innerHTML = "";

    if (type === "image") {
      const img = document.createElement("img");
      img.src = src;
      img.className = "max-h-[90vh] max-w-[90vw] rounded-2xl shadow-2xl";
      content.appendChild(img);
    }

    if (type === "video") {
      const video = document.createElement("video");
      video.src = src;
      video.controls = true;
      video.autoplay = true;
      video.className = "max-h-[90vh] max-w-[90vw] rounded-2xl shadow-2xl";
      content.appendChild(video);
    }

    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");

  });

});

closeBtn.addEventListener("click",closeLightbox);

lightbox.addEventListener("click",(e)=>{

    if(e.target===lightbox){

        closeLightbox();

    }

});

window.addEventListener("keydown",(e)=>{

    if(e.key==="Escape"){

        closeLightbox();

    }

});

});

</script>
</Layout>