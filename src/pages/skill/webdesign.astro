---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Web Design" activePage="skills">
  <main class="py-16">
    <div class="wrap">
      <a href="/skills" class="text-sm font-mono text-paper-dim hover:text-mint transition-colors">&larr; Back to Tracks</a>
      <h1 class="text-4xl font-display font-bold mt-4 mb-2">Web Design</h1>
      <p class="text-paper-dim max-w-2xl mb-12">Assembling component interfaces with clean layout semantics.</p>

      <h3 class="text-xl font-mono text-mint mb-6">Build Logs</h3>
      <div class="gallery-grid">
        <div class="gallery-item"><span>index.html</span></div>
        <div class="gallery-item"><span>global.css</span></div>
        <div class="gallery-item"><span>main.js</span></div>
      </div>
    </div>
  </main>
</Layout>