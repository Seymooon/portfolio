---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" activePage="contact">
  <main class="py-16">
    <div class="wrap max-w-2xl">
      <span class="text-xs font-mono tracking-widest text-coral uppercase block mb-3">// COMMUNICATIONS_PANEL</span>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-paper mb-4">Let's Connect</h1>
      <p class="text-lg text-paper-dim mb-8">Reach out instantly via the visual channels below or use the direct mail engine link.</p>

      <div class="ruler static mb-12" role="presentation"></div>

      <div class="space-y-8">
        <div>
          <a href="mailto:johnsimongutang@gmail.com" class="btn btn-primary bg-coral text-ink font-mono px-8 py-4 rounded-md font-bold text-center inline-block hover:opacity-90 transition-opacity">
            Launch Email: johnsimongutang@gmail.com
          </a>
          <p class="text-xs font-mono text-paper-dim mt-3">
            or save my email for later: <span class="text-gold select-all">johnsimongutang@gmail.com</span>
          </p>
        </div>

        <div class="pt-6 border-t border-line space-y-4">
          <h3 class="text-sm font-mono text-paper-dim uppercase tracking-wider">[ Alternative Instant Channels ]</h3>
          <div class="flex flex-col gap-3">
            <a href="https://www.linkedin.com/feed/" target="_blank" class="text-paper hover:text-mint transition-colors font-body text-lg flex items-center gap-2">
              &rarr; LinkedIn Profile
            </a>
            <a href="https://t.me/Fiochmhar" target="_blank" class="text-paper hover:text-coral transition-colors font-body text-lg flex items-center gap-2">
              &rarr; Telegram: @Fiochmhar
            </a>
            <a href="https://wa.me/639959305442" target="_blank" class="text-paper hover:text-gold transition-colors font-body text-lg flex items-center gap-2">
              &rarr; WhatsApp: +63 995 930 5442
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>