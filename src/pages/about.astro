---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Me" activePage="about">
  <main class="py-16">
    <div class="wrap max-w-6xl">

      <!-- Section Header -->
      <span class="text-xs font-mono tracking-widest text-accent uppercase block mb-2">
        Focus on what matters. I'll handle the details.
      </span>

      <h1 class="text-4xl md:text-5xl font-display font-bold text-paper mb-8">
        About Me
      </h1>

      <!-- Biography -->
      <div class="grid lg:grid-cols-[380px_1fr] gap-16 items-start">
      <div class="flex justify-center lg:justify-start">

  <div id="profile-card">

    <img
      src="/media/Photo.jpg"
      alt="John"
      draggable="false"
      class="h-full w-full object-cover pointer-events-none select-none"
    />

  </div>

</div>

<div class="space-y-7 text-[1.08rem] md:text-lg text-paper-dim font-body leading-8 md:leading-9 text-left md:text-justify">

        <p>
          I'm a psychology graduate, HR professional, and creative problem solver with experience spanning recruitment, administrative operations, digital media, and visual communication. I enjoy bringing structure to busy workflows, simplifying complex processes, and creating solutions.
        </p>

        <p>
          Throughout my career, I've supported recruitment initiatives, coordinated hiring activities, managed documentation and confidential records, produced promotional content, and collaborated with diverse teams to achieve shared goals. Whether the task involves organization, communication, or creativity, I approach it with professionalism, curiosity, and meticulous attention to detail.
        </p>

        <p>
  I'm passionate about continuous learning and believe that every new challenge is an opportunity to grow.
</p>

</div> <!-- closes biography -->

</div> <!-- closes grid -->

<!-- Strengths -->
      <h2 class="text-2xl font-display font-bold text-paper mt-16 mb-8">
        Strengths
      </h2>

      <div class="timeline-track">

        <!-- HR -->
        <div class="timeline-item">
          <span class="timecode">
            HR, RECRUITMENT, & ADMINISTRATIVE OPERATIONS
          </span>

          <h3 class="text-2xl font-display font-bold text-paper mb-3">
            Recruitment, Coordination & Administrative Support
          </h3>

          <p class="text-paper-dim text-[1.03rem] md:text-[1.08rem] leading-8">
            Managed recruitment processes from talent sourcing and resume screening to interviews, onboarding, and orientation. Maintained confidential employee records, organized digital documentation, handled professional email correspondence, coordinated with internal teams and external partners, and kept recruitment workflows accurate, organized, and efficient while balancing multiple priorities.
          </p>
        </div>

        <!-- Content -->
        <div class="timeline-item">
          <span class="timecode">
            DIGITAL CONTENT & BRAND COMMUNICATION
          </span>

          <h3 class="text-2xl font-display font-bold text-paper mb-3">
            Creative Media & Social Media Management
          </h3>

          <p class="text-paper-dim text-[1.03rem] md:text-[1.08rem] leading-8">
            Created promotional graphics and managed Facebook and LinkedIn recruitment campaigns to strengthen employer branding and audience engagement. Produced marketing materials and edited promotional videos while ensuring every piece of content remained visually consistent, purposeful, and aligned with organizational goals.
          </p>
        </div>

        <!-- Professional -->
        <div class="timeline-item">
          <span class="timecode">
            PROFESSIONAL APPROACH
          </span>

          <h3 class="text-2xl font-display font-bold text-paper mb-3">
            Adaptability, Initiative, & Continuous Learning
          </h3>

          <p class="text-paper-dim text-[1.03rem] md:text-[1.08rem] leading-8">
            This portfolio reflects the way I approach every challenge. Despite having no formal background in web development, I independently learned modern development tools and built this website from the ground up with AI serving as a collaborative learning partner. That experience reinforced qualities I value most: resourcefulness, adaptability, reliability, attention to detail, and the confidence to quickly learn unfamiliar systems.
          </p>
        </div>

      </div>

    </div>
  </main>
  <style>

#profile-card{

width:340px;
aspect-ratio:3/4;

border-radius:28px;

overflow:hidden;

background:var(--surface);

border:1px solid var(--line);

cursor:grab;

user-select:none;

touch-action:none;

transform-style:preserve-3d;

transition:
transform .2s ease,
box-shadow .2s ease;

box-shadow:
0 30px 70px rgba(0,0,0,.18);

}

:root[data-theme="dark"] #profile-card{

box-shadow:
0 35px 80px rgba(0,0,0,.45);

}

#profile-card img{

width:100%;
height:100%;
object-fit:cover;

pointer-events:none;

}

@media (max-width:1024px){

#profile-card{

width:280px;

margin-bottom:2rem;

}

}

</style>
<script is:inline>

document.addEventListener("astro:page-load",()=>{

const card=document.getElementById("profile-card");

if(!card) return;

let dragging=false;

let startX=0;
let startY=0;

let x=0;
let y=0;

card.addEventListener("pointerdown",(e)=>{

dragging=true;

startX=e.clientX-x;
startY=e.clientY-y;

card.setPointerCapture(e.pointerId);

});

card.addEventListener("pointermove",(e)=>{

const rect=card.getBoundingClientRect();

if(!dragging){

const mx=e.clientX-rect.left;
const my=e.clientY-rect.top;

const rx=(rect.height/2-my)/18;
const ry=(mx-rect.width/2)/18;

card.style.transform=`
rotateX(${rx}deg)
rotateY(${ry}deg)
`;

return;

}

x=e.clientX-startX;
y=e.clientY-startY;

card.style.transform=`
translate(${x}px,${y}px)
rotate(${x*.04}deg)
`;

});

card.addEventListener("pointerup",()=>{

dragging=false;

x=0;
y=0;

card.style.transition="transform .5s cubic-bezier(.2,.9,.2,1.2)";

card.style.transform="translate(0,0)";

setTimeout(()=>{

card.style.transition="transform .2s ease";

},500);

});

card.addEventListener("mouseleave",()=>{

if(dragging) return;

card.style.transform="rotateX(0deg) rotateY(0deg)";

});

});

</script>
</Layout>