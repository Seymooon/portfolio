---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Skills" activePage="skills">
  <main class="py-16">
    <div class="wrap">
      <h2 class="text-4xl font-display font-bold mb-6">Skills & Specialties</h2>
      
      <div class="timeline-track">
        <div class="timeline-item">
          <span class="timecode">TRACK_01 // VISUAL</span>
          <h3 class="text-xl font-bold mb-2">Video Editing</h3>
          <p class="text-paper-dim mb-4">Pacing, structure, continuity and dynamic audio-visual alignment.</p>
          <a href="/skill/video" class="text-coral hover:underline font-mono text-sm">Open Track &rarr;</a>
        </div>

        <div class="timeline-item">
          <span class="timecode">TRACK_02 // INTERACTIVE</span>
          <h3 class="text-xl font-bold mb-2">Web Design</h3>
          <p class="text-paper-dim mb-4">Building structural components, lighting-fast layouts, and responsive rules.</p>
          <a href="/skill/webdesign" class="text-mint hover:underline font-mono text-sm">Open Track &rarr;</a>
        </div>

        <div class="timeline-item">
          <span class="timecode">TRACK_03 // CREATIVE</span>
          <h3 class="text-xl font-bold mb-2">Digital Art</h3>
          <p class="text-paper-dim mb-4">Illustration, concept asset composition, and atmospheric coloring.</p>
          <a href="/skill/artist" class="text-gold hover:underline font-mono text-sm">Open Track &rarr;</a>
        </div>
      </div>
    </div>
  </main>
</Layout>