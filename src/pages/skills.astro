---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Skills" activePage="skills">
  <main class="py-16">
    <div class="wrap">
      <h2 class="text-4xl font-display font-bold mb-6">Skills & Specialties</h2>
      
      <div class="timeline-track">
        <div class="timeline-item">
          <span class="text-accent font-mono text-sm tracking-widest">OPERATIONS</span>
          <h3 class="text-xl font-bold mb-2">Email and data management</h3>
          <p class="text-paper-dim mb-4">Organizing communication flows, maintaining databases, and executing inbox zero strategies.</p>
          <a href="/skill/email" class="text-accent hover:underline font-mono text-sm">Open &rarr;</a>
        </div>

        <div class="timeline-item">
          <span class="text-accent font-mono text-sm tracking-widest">STRATEGY</span>
          <h3 class="text-xl font-bold mb-2">Social media management</h3>
          <p class="text-paper-dim mb-4">Content scheduling, community engagement, and brand consistency across platforms.</p>
          <a href="/skill/social" class="text-accent hover:underline font-mono text-sm">Open &rarr;</a>
        </div>

        <div class="timeline-item">
          <span class="text-accent font-mono text-sm tracking-widest">MEDIA</span>
          <h3 class="text-xl font-bold mb-2">Video and gfx samples</h3>
          <p class="text-paper-dim mb-4">Dynamic post-production, motion assets, and custom graphic design compositions.</p>
          <a href="/skill/media" class="text-accent hover:underline font-mono text-sm">Open &rarr;</a>
        </div>
      </div>
    </div>
  </main>
</Layout>