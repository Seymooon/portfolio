---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home" activePage="home">

  <main class="space-y-0">

    <!-- HERO -->
    <section class="wrap min-h-screen py-20 lg:flex lg:items-center pb-32">
    <!-- Mobile tagline -->
<div class="lg:hidden mb-8">
  <span class="text-xs uppercase tracking-[0.35em] font-mono text-accent">
    Administrative • Creative • Client Relations
  </span>
</div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <!-- TEXT -->
        <div class="order-2 lg:order-1 max-w-2xl">

          <span class="hidden lg:inline text-xs uppercase tracking-[0.35em] font-mono text-accent">
            Administrative • Creative • Client Relations
          </span>

          <h1 class="mt-6 text-5xl sm:text-6xl lg:text-7xl font-display font-bold leading-[1.05] text-paper">
            Focus on what matters.
            <br />
            I'll handle the details.
          </h1>

          <p class="mt-8 max-w-xl text-lg md:text-xl leading-relaxed text-paper-dim">
            Helping businesses stay organized through administrative support,
            creative media, and professional communication so you can focus on
            growing your business.
          </p>

          <div class="mt-10 flex flex-wrap gap-4">

            <a
              href="/skills"
              class="rounded-md bg-accent px-7 py-3 font-medium text-ink hover:opacity-90 transition"
            >
              View My Work
            </a>

            <a
              href="/contact"
              class="rounded-md border border-line px-7 py-3 text-paper hover:bg-surface transition"
            >
              Let's Connect
            </a>

          </div>

        </div>

        <!-- IMAGE -->
        <div class="order-1 lg:order-2 flex justify-center">

          <img
            src="/Photo.jpg"
            alt="John Simon Gutang"
            class="w-full max-w-sm md:max-w-md lg:max-w-lg rounded-3xl border border-line object-cover"
          />

        </div>

      </div>

    </section>

    <!-- SERVICES -->
    <section class="wrap pb-32">

      <h2 class="text-4xl md:text-5xl font-display font-bold text-paper">
        How I Can Help
      </h2>

      <div class="mt-12 mb-24 md:mb-32 grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="rounded-xl border border-line bg-surface p-8">
          <h3 class="mb-6 text-2xl font-display font-bold text-paper">
            Administrative
          </h3>

          <ul class="space-y-4 text-paper-dim">
            <li>• Inbox & Email Management</li>
            <li>• Calendar Scheduling</li>
            <li>• Data Entry & Organization</li>
            <li>• Spreadsheet Management</li>
          </ul>
        </div>

        <div class="rounded-xl border border-line bg-surface p-8">
          <h3 class="mb-6 text-2xl font-display font-bold text-paper">
            Creative
          </h3>

          <ul class="space-y-4 text-paper-dim">
            <li>• Email Design</li>
            <li>• Social Media Graphics</li>
            <li>• Short-form Video Editing</li>
            <li>• Content Planning</li>
          </ul>
        </div>

        <div class="rounded-xl border border-line bg-surface p-8">
          <h3 class="mb-6 text-2xl font-display font-bold text-paper">
            Client Support
          </h3>

          <ul class="space-y-4 text-paper-dim">
            <li>• Professional Communication</li>
            <li>• Client Follow-ups</li>
            <li>• Recruitment Coordination</li>
            <li>• Social Media Management</li>
          </ul>
        </div>

      </div>

    </section>

    <!-- ABOUT + PORTFOLIO -->
    <section class="wrap pb-12">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-stretch">

        <div class="flex flex-col h-full">

          <h2 class="text-4xl font-display font-bold text-paper">
            About Me
          </h2>

          <p class="mt-6 flex-1 max-w-lg leading-8 text-paper-dim">
            Psychology graduate with experience in recruitment,
            administrative operations, and creative media. I enjoy
            creating organized systems, streamlining workflows,
            and helping businesses operate more efficiently.
          </p>

          <a
            href="/about"
            class="mt-10 inline-flex text-accent hover:underline"
          >
            Learn More →
          </a>

        </div>

        <div class="flex flex-col h-full">

          <h2 class="text-4xl font-display font-bold text-paper">
            Featured Work
          </h2>

          <p class="mt-6 flex-1 max-w-lg leading-8 text-paper-dim">
            Browse projects in email marketing, visual design,
            social media, recruitment support, and administrative
            systems designed to help businesses communicate more effectively.
          </p>

          <a
            href="/skills"
            class="mt-10 inline-flex text-accent hover:underline"
          >
            View Portfolio →
          </a>

        </div>

      </div>

    </section>

    <!-- Space before footer -->
    <div class="h-12"></div>

  </main>

</Layout>